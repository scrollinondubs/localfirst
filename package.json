{
  "name": "local-first-arizona",
  "version": "1.0.0",
  "description": "Local First Arizona Chrome Extension, Mobile App, and Backend API",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm run dev --workspace=packages/api",
    "dev:extension": "npm run build --workspace=packages/extension",
    "dev:mobile": "npm run start --workspace=packages/mobile",
    "dev:mobile:web": "npm run web --workspace=packages/mobile",
    "dev:mobile:ios": "npm run ios --workspace=packages/mobile",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:mobile:web\"",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=packages/api",
    "build:extension": "npm run build --workspace=packages/extension",
    "build:mobile": "npm run build:web --workspace=packages/mobile",
    "db:setup": "npm run db:setup --workspace=packages/api",
    "db:migrate": "npm run db:migrate --workspace=packages/api",
    "db:seed": "npm run db:seed --workspace=packages/api",
    "db:chains": "npm run db:chains --workspace=packages/api",
    "test": "npm run test --workspaces --if-present",
    "test:api": "npm run test --workspace=packages/api",
    "test:extension": "npm run test --workspace=packages/extension",
    "test:mobile": "npm run test --workspace=packages/mobile"
  },
  "keywords": ["chrome-extension", "mobile-app", "local-business", "arizona", "maps", "react-native", "expo"],
  "author": "Local First Arizona",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^3.0.0",
    "eslint": "^8.0.0",
    "concurrently": "^8.2.2"
  }
}