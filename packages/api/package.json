{
  "name": "@local-first/api",
  "version": "1.0.0",
  "description": "Local First Arizona API",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node dev-server.js",
    "dev:wrangler": "wrangler dev src/index.js",
    "build": "wrangler deploy --dry-run",
    "deploy": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy --env development",
    "deploy:preview": "wrangler deploy --dry-run",
    "d1:create": "wrangler d1 create localfirst-prod",
    "d1:create:dev": "wrangler d1 create localfirst-dev",
    "d1:migrate": "wrangler d1 migrations apply localfirst-prod --env production",
    "d1:migrate:dev": "wrangler d1 migrations apply localfirst-dev --env development",
    "d1:query": "wrangler d1 execute localfirst-prod --command",
    "d1:console": "wrangler d1 execute localfirst-prod --command 'SELECT 1'",
    "cf:tail": "wrangler tail --env production",
    "cf:tail:dev": "wrangler tail --env development",
    "cf:logs": "wrangler pages deployment tail",
    "cf:secrets:list": "wrangler secret list",
    "cf:secrets:put": "wrangler secret put",
    "db:setup": "node scripts/setup-db.js",
    "db:migrate": "drizzle-kit push:sqlite",
    "db:seed": "node scripts/seed-data.js",
    "db:import": "node scripts/import-businesses.js",
    "db:chains": "node scripts/seed-chains.js",
    "db:verify": "node scripts/verify-database.js",
    "db:fix-coordinates": "node scripts/fix-coordinates.js",
    "db:reset": "rm -f local.db && npm run db:setup && npm run db:seed",
    "support:check": "node scripts/check-support-tickets.js",
    "support:count": "node scripts/check-support-tickets.js --count",
    "test": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^1.18.1",
    "@libsql/client": "^0.4.3",
    "@noble/hashes": "^1.8.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.29.5",
    "hono": "^4.9.0",
    "jsonwebtoken": "^9.0.2",
    "openai": "^4.104.0",
    "uuid": "^9.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "drizzle-kit": "^0.20.18",
    "vitest": "^1.0.0",
    "wrangler": "^4.31.0"
  }
}
