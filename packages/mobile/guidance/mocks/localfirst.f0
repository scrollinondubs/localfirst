\n  (def! lh (* h 0.15))\n  (def! island (. shape :getPropertyValue \"Island\"))\n  (def! landscape (< h w))\n  (. canvas :strokeRoundRect l t r b 44)\n  (. canvas :strokeRoundRect (- l g) (- t g) (+ r g) (+ b g) 50)\n  (if island\n    (if landscape\n      (. canvas :strokeRoundRect\n         (+ l g) (- y lh) (+ l (* g 3)) (+ y lh) g)\n      (. canvas :strokeRoundRect\n         (- x lw) (+ t g) (+ x lw) (+ t (* g 3)) g))))"},{"id":"viewport","script":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! g 10)\n  [[(- l g) (- t g)] [(+ r g) (+ b g)]])"}],"corners":[42,42,42,42],"textEditable":false}],"name":"Business Details","enable":false,"pageOrigin":[332,68]},{"id":"8fAfEltEU0Dthzu3BMpHc","type":"Page","parent":"gi2yu0UHPJEB1lj5t6CDx","children":[{"id":"Is892nMJaZmfyfgXjrdKP","type":"Frame","parent":"8fAfEltEU0Dthzu3BMpHc","children":[{"id":"3-H1HTWh2k1hogc7rJJoR","type":"Text","parent":"Is892nMJaZmfyfgXjrdKP","name":"Management Title","left":60,"top":80,"width":185,"height":32,"strokeWidth":2,"fillStyle":"none","fontFamily":"Loranthus","fontSize":24,"roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"Manage Business"}]}]},"horzAlign":"left","vertAlign":"top"},{"id":"A-UGu-f9HJRcUVftzrKbb","type":"Text","parent":"Is892nMJaZmfyfgXjrdKP","name":"Menu Options","left":40,"top":140,"width":169,"height":118,"strokeWidth":2,"fillStyle":"none","fontFamily":"Loranthus","roughness":1,"constraints":[{"id":"set-size","width":"text","height":"text"}],"text":{"type":"doc","content":[{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"📝 Edit Business Info"}]},{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"📸 Manage Photos  "}]},{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"🕐 Update Hours"}]},{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"📢 Create Promotions"}]},{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"📊 View Analytics"}]},{"type":"paragraph","attrs":{"textAlign":"left"},"content":[{"type":"text","text":"⚙️ Settings"}]}]},"wordWrap":true,"horzAlign":"left","vertAlign":"top"}],"name":"Business Management Frame","tags":["frame"],"rotatable":false,"containable":true,"width":320,"height":690,"strokeWidth":2,"fontFamily":"Loranthus","fontSize":18,"roughness":1,"properties":[{"name":"Island","type":"boolean","value":true}],"scripts":[{"id":"render","script":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! w (. shape :width))\n  (def! h (. shape :height))\n  (def! x (/ (+ l r) 2))\n  (def! y (/ (+ t b) 2))\n  (def! seed (. shape :getSeed))\n  (def! g 10)\n  (def! lw (* w 0.15))\n  (def! lh (* h 0.15))\n  (def! island (. shape :getPropertyValue \"Island\"))\n  (def! landscape (< h w))\n  (. canvas :strokeRoundRect l t r b 44)\n  (. canvas :strokeRoundRect (- l g) (- t g) (+ r g) (+ b g) 50)\n  (if island\n    (if landscape\n      (. canvas :strokeRoundRect\n         (+ l g) (- y lh) (+ l (* g 3)) (+ y lh) g)\n      (. canvas :strokeRoundRect\n         (- x lw) (+ t g) (+ x lw) (+ t (* g 3)) g))))"},{"id":"viewport","script":"(do\n  (def! l (. shape :left))\n  (def! r (. shape :right))\n  (def! t (. shape :top))\n  (def! b (. shape :bottom))\n  (def! g 10)\n  [[(- l g) (- t g)] [(+ r g) (+ b g)]])"}],"corners":[42,42,42,42],"textEditable":false}],"name":"Business Management","enable":false,"pageOrigin":[334,65]}]}