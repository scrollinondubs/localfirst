{
  "name": "local-first-arizona",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "web:dev": "expo start --web --port 3000",
    "build:web": "expo export:web --clear",
    "build:production": "NODE_ENV=production expo export --platform web --output-dir web-build --clear",
    "build:preview": "NODE_ENV=preview expo export:web --clear",
    "test": "playwright test",
    "test:debug": "playwright test --debug",
    "test:watch": "playwright test --watch",
    "test:autonomous": "playwright test tests/app-autonomous.spec.js --headed",
    "test:dashboard": "playwright test tests/debug-dashboard.spec.js --headed",
    "test:quick": "playwright test tests/quick-validation.spec.js --project=chromium --headed",
    "debug:autonomous": "playwright test tests/debug-dashboard.spec.js --headed --project=chromium",
    "demo:autonomous": "node scripts/autonomous-demo.js",
    "deploy": "npm run build:web && npx serve dist",
    "dev:autonomous": "concurrently \"npm run web:dev\" \"npm run test:watch\"",
    "test:ios": "./scripts/autonomous-ios-test.sh",
    "build:ios": "./scripts/autonomous-ios-test.sh --build",
    "install:ios": "./scripts/autonomous-ios-test.sh --install"
  },
  "dependencies": {
    "@expo/metro-runtime": "~5.0.4",
    "@expo/ngrok": "^4.1.3",
    "@googlemaps/markerclusterer": "^2.5.3",
    "@react-native-async-storage/async-storage": "^1.24.0",
    "@react-navigation/bottom-tabs": "^7.4.6",
    "@react-navigation/native": "^7.1.17",
    "@react-navigation/stack": "^7.4.7",
    "expo": "~53.0.20",
    "expo-av": "^15.1.7",
    "expo-dev-client": "~5.2.4",
    "expo-haptics": "^14.1.4",
    "expo-location": "^18.1.6",
    "expo-speech": "^13.1.7",
    "expo-status-bar": "~2.2.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-native": "0.79.5",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.15.0",
    "react-native-web": "^0.20.0",
    "snack-sdk": "^6.5.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@playwright/test": "^1.55.0",
    "@types/react": "~19.0.10",
    "concurrently": "^8.2.2",
    "typescript": "~5.8.3"
  },
  "private": true
}
