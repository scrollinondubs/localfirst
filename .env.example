# LocalFirst Arizona - Environment Variables Template
# Copy this file to create your environment-specific .env files

# =============================================================================
# API ENVIRONMENT VARIABLES (packages/api)
# =============================================================================

# JWT Secret (generate with: openssl rand -base64 32)
JWT_SECRET=your-super-secret-jwt-key-here

# Database Configuration
# For local development, use SQLite file
DATABASE_URL=file:../../local.db

# For production with D1, these are handled by Wrangler automatically
# D1_DATABASE_ID=your-d1-database-id

# Environment
NODE_ENV=development

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,chrome-extension://

# =============================================================================
# MOBILE APP ENVIRONMENT VARIABLES (packages/mobile)
# =============================================================================

# API Configuration
REACT_APP_API_URL=http://localhost:8787
REACT_APP_API_BASE_URL=http://localhost:8787/api

# App Configuration
REACT_APP_NAME=LocalFirst Arizona
REACT_APP_VERSION=1.0.0
REACT_APP_ENV=development

# Features
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_LOGGING=true

# =============================================================================
# PRODUCTION OVERRIDES
# =============================================================================

# For production, create .env.production files with these values:

# API Production (set as Cloudflare Workers secrets)
# JWT_SECRET=your-production-jwt-secret
# NODE_ENV=production

# Mobile App Production (set in Cloudflare Pages)
# REACT_APP_API_URL=https://your-worker.workers.dev
# REACT_APP_API_BASE_URL=https://your-worker.workers.dev/api
# REACT_APP_ENV=production
# REACT_APP_ENABLE_ANALYTICS=true
# REACT_APP_ENABLE_LOGGING=false

# =============================================================================
# CLOUDFLARE CONFIGURATION
# =============================================================================

# Set these for local Wrangler CLI usage
# CLOUDFLARE_API_TOKEN=your-api-token
# CLOUDFLARE_ACCOUNT_ID=your-account-id

# Or use: wrangler login (interactive browser auth)

# =============================================================================
# OPTIONAL: EXTERNAL SERVICES
# =============================================================================

# Error Tracking (if using Sentry)
# SENTRY_DSN=your-sentry-dsn
# SENTRY_ORG=your-sentry-org
# SENTRY_PROJECT=your-sentry-project

# Analytics (if using custom analytics)
# ANALYTICS_API_KEY=your-analytics-key

# =============================================================================
# DEVELOPMENT NOTES
# =============================================================================

# 1. Never commit real secrets to git
# 2. Use different secrets for dev/staging/production
# 3. JWT secrets should be at least 32 characters
# 4. API URLs should not have trailing slashes
# 5. Use HTTPS in production for geolocation/microphone features